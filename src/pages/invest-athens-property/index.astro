---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
import InlineCta from '../../components/InlineCta.astro';

const title = 'Invest in Athens Property 2026, Golden Visa & Yields';
const description = 'Invest in Athens property from €800K Golden Visa stock or LTR yield districts. Riviera, center, and north Athens, vetted shortlist support.';
---

<BaseLayout
  {title}
  {description}
  canonical="https://greek-invest.com/invest-athens-property/"
>
  <section class="bg-[#0f2744] text-white">
    <div class="site-container py-14 md:py-18 max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-[#93c5fd] mb-3">Athens · Attica</p>
      <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-4 text-white">Invest in Athens property in 2026</h1>
      <p class="text-lg text-[#cbd5e1] leading-relaxed mb-6">
        Greece's largest market: €626M in Athens municipality sales in 2025, €800,000 Golden Visa threshold across Attica,
        and city-wide gross yields near 5.43% with working-class districts reaching 6 to 7.5% on long-term leases.
      </p>
      <a href="/get-shortlist/" class="btn-primary">Get Athens shortlist</a>
    </div>
  </section>

  <section class="site-container py-12 max-w-3xl text-[var(--color-muted)] leading-relaxed">
    <h2 class="text-[var(--color-ink)] mb-4">Three Athens investment profiles</h2>
    <ul class="space-y-4 mb-8">
      <li><strong class="text-[var(--color-ink)]">Athenian Riviera (Glyfada, Voula, Ellinikon)</strong>, capital preservation, marina lifestyle, tram and regeneration pipeline. See the <a href="/guides/athens-property-investment-guide/">Athens investment guide</a> and <a href="/areas/glyfada-property-investment/">Glyfada area guide</a>.</li>
      <li><strong class="text-[var(--color-ink)]">Central Athens</strong>, tourism adjacency but STR moratorium in saturated districts; Golden Visa assets still require LTR-only income. Read the <a href="/compare/athens-riviera-vs-athens-center-investment/">Riviera vs center comparison</a>.</li>
      <li><strong class="text-[var(--color-ink)]">Northern working-class belt</strong>, highest indicative LTR yields (Kipseli, Patisia) with lower €/m² than the Riviera. Covered in the <a href="/guides/highest-rental-yield-areas-greece/">yield by area guide</a>.</li>
    </ul>

    <InlineCta
      text="Every Attica purchase for Golden Visa needs €800,000 on one property of at least 120 m², confirm your zone before you offer."
      buttonText="Golden Visa zone checker"
      buttonHref="/tools/greece-golden-visa-zone-lookup/"
    />

    <p class="mb-10">
      Full due diligence stack: <a href="/guides/athens-golden-visa-800000-areas/">€800K areas</a> ·
      <a href="/guides/ellinikon-athens-property-investment/">Ellinikon regeneration</a> ·
      <a href="/guides/due-diligence-greece-property/">property due diligence</a> ·
      <a href="/guides/cost-of-buying-property-greece/">buying costs</a>
    </p>

    <LeadForm
      title="Request Athens property shortlist"
      subtitle="Riviera · center · north Athens · GV-ready screening"
      context="Invest Athens commercial page"
    />
  </section>
</BaseLayout>
