---
export const prerender = true;

const reportDate = '25 June 2026';
const reportVersion = 'v1.0';
const launchDate = '17 June 2026';
const dataThrough = '25 June 2026';

const monthlyGsc = [
  { month: 'Jun 2026', label: 'Jun', clicks: 0, impressions: 89, position: 18.8, note: 'Launch · first GSC crawl 19 Jun · Silo E complete' },
];

const monthlyGa4 = [
  { month: 'Jun', sessions: 34 },
];

const contentBreakdown = [
  { type: 'Guides', count: 66, words: 173206, color: '#2d7a5e' },
  { type: 'Areas', count: 12, words: 24798, color: '#8b5cf6' },
  { type: 'Compare', count: 6, words: 13317, color: '#d97706' },
  { type: 'Projects', count: 3, words: 4531, color: '#4e9e7e' },
  { type: 'Developers', count: 4, words: 6786, color: '#60a5fa' },
  { type: 'News', count: 1, words: 1192, color: '#9ca3af' },
];

const totalClicks = monthlyGsc.reduce((s, m) => s + m.clicks, 0);
const totalImp = monthlyGsc.reduce((s, m) => s + m.impressions, 0);
const totalWords = contentBreakdown.reduce((s, c) => s + c.words, 0);
const totalFiles = contentBreakdown.reduce((s, c) => s + c.count, 0);
const clicksDelta = 0;
const maxImp = Math.max(...monthlyGsc.map(m => m.impressions));
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>greek-invest.com, Site Report</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f4f1eb; color: #2c2c2c; min-height: 100vh; }

    .header { background: #1a2e2a; color: white; padding: 32px 40px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
    .header-brand { display: flex; align-items: center; gap: 12px; }
    .header-logo { width: 36px; height: 36px; background: #4e9e7e; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 18px; color: white; }
    .header h1 { font-size: 22px; font-weight: 700; }
    .header-sub { font-size: 13px; color: #9dbfb3; margin-top: 2px; }
    .header-meta { text-align: right; }
    .header-meta .label { font-size: 12px; color: #9dbfb3; }
    .header-meta .value { font-size: 14px; font-weight: 600; margin-top: 2px; }
    .live-badge { display: inline-flex; align-items: center; gap: 6px; background: #2d5a4a; border-radius: 20px; padding: 4px 12px; font-size: 12px; margin-top: 8px; }
    .live-dot { width: 6px; height: 6px; background: #4ade80; border-radius: 50%; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

    .container { max-width: 1280px; margin: 0 auto; padding: 32px 24px; }

    .section-title { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #7a7a6e; margin-bottom: 16px; margin-top: 40px; }
    .section-title:first-child { margin-top: 0; }

    .stats-grid { display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); gap: 10px; }
    .stat-card { background: white; border-radius: 10px; padding: 14px 10px; border: 1px solid #e8e4dc; min-width: 0; }
    .stat-card .num { font-size: 26px; font-weight: 800; color: #1a2e2a; line-height: 1.05; letter-spacing: -0.02em; }
    .stat-card .num.teal { color: #2d7a5e; }
    .stat-card .num.amber { color: #b45309; }
    .stat-card .label { font-size: 11px; color: #7a7a6e; margin-top: 5px; line-height: 1.25; }
    .stat-card .sublabel { font-size: 9px; color: #aaa; margin-top: 3px; line-height: 1.35; }
    @media (max-width: 1100px) { .stats-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } }

    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    @media (max-width: 600px) { .info-grid { grid-template-columns: 1fr; } }
    .info-card { background: white; border-radius: 12px; padding: 20px; border: 1px solid #e8e4dc; }
    .info-card h3 { font-size: 14px; font-weight: 700; color: #1a2e2a; margin-bottom: 14px; padding-bottom: 10px; border-bottom: 1px solid #f0ece4; }
    .info-row { display: flex; justify-content: space-between; align-items: flex-start; padding: 6px 0; border-bottom: 1px solid #f7f4ef; gap: 16px; }
    .info-row:last-child { border-bottom: none; }
    .info-row .key { font-size: 13px; color: #7a7a6e; flex-shrink: 0; }
    .info-row .val { font-size: 13px; font-weight: 600; color: #2c2c2c; text-align: right; }
    .info-row .val a { color: #2d7a5e; text-decoration: none; }
    .info-row .val a:hover { text-decoration: underline; }

    .content-card { background: white; border-radius: 12px; border: 1px solid #e8e4dc; overflow: hidden; }
    .table-scroll { width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .content-table { width: 100%; border-collapse: collapse; }
    .content-table th { font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: #7a7a6e; font-weight: 700; padding: 12px 20px; text-align: left; background: #faf8f4; border-bottom: 1px solid #e8e4dc; }
    .content-table td { padding: 12px 20px; font-size: 13px; border-bottom: 1px solid #f4f1eb; vertical-align: top; }
    .content-table tr:last-child td { border-bottom: none; }
    .content-table tr:hover td { background: #faf8f4; }
    .content-table .count { font-weight: 800; color: #2d7a5e; font-size: 18px; }
    .content-table .words { color: #7a7a6e; font-size: 12px; }
    .tag { display: inline-block; padding: 2px 8px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .tag.green { background: #dcfce7; color: #166534; }
    .tag.blue { background: #dbeafe; color: #1e40af; }
    .tag.amber { background: #fef3c7; color: #92400e; }
    .tag.gray { background: #f3f4f6; color: #374151; }

    .changelog { display: flex; flex-direction: column; gap: 0; }
    .changelog-item { background: white; border-radius: 0; border: 1px solid #e8e4dc; border-bottom: none; padding: 16px 20px; display: flex; gap: 16px; align-items: flex-start; }
    .changelog-item:first-child { border-radius: 12px 12px 0 0; }
    .changelog-item:last-child { border-radius: 0 0 12px 12px; border-bottom: 1px solid #e8e4dc; }
    .changelog-date { font-size: 11px; color: #9ca3af; min-width: 80px; padding-top: 2px; }
    .changelog-content { flex: 1; }
    .changelog-title { font-size: 13px; font-weight: 600; color: #1a2e2a; }
    .changelog-desc { font-size: 12px; color: #7a7a6e; margin-top: 3px; }
    .changelog-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 6px; }

    .next-steps { display: flex; flex-direction: column; gap: 10px; }
    .next-item { background: white; border-radius: 10px; border: 1px solid #e8e4dc; padding: 14px 18px; display: flex; align-items: flex-start; gap: 12px; }
    .next-item .priority { font-size: 11px; font-weight: 700; min-width: 50px; padding-top: 1px; }
    .priority.high { color: #dc2626; }
    .priority.medium { color: #d97706; }
    .priority.low { color: #059669; }
    .next-item .text { font-size: 13px; color: #2c2c2c; }
    .next-item .subtext { font-size: 12px; color: #9ca3af; margin-top: 2px; }

    .links-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px; }
    .link-card { background: white; border-radius: 10px; border: 1px solid #e8e4dc; padding: 16px; text-decoration: none; color: #2c2c2c; transition: border-color 0.2s; display: block; }
    .link-card:hover { border-color: #2d7a5e; }
    .link-card .link-label { font-size: 11px; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.06em; }
    .link-card .link-url { font-size: 13px; font-weight: 600; color: #2d7a5e; margin-top: 4px; word-break: break-all; }

    .footer { text-align: center; padding: 32px 24px; color: #9ca3af; font-size: 12px; }
    .footer strong { color: #7a7a6e; }

    /* ── SEO PULSE DASHBOARD ── */
    .pulse-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; }
    .pulse-header h2 { font-size: 16px; font-weight: 800; color: #1a2e2a; }
    .pulse-updated { font-size: 11px; color: #9ca3af; background: #f4f1eb; border-radius: 20px; padding: 4px 12px; display: flex; align-items: center; gap: 6px; }
    .pulse-updated-dot { width: 6px; height: 6px; border-radius: 50%; background: #4ade80; animation: pulse 2s infinite; }

    .pulse-kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 20px; }
    @media (max-width: 700px) { .pulse-kpi-row { grid-template-columns: repeat(2, 1fr); } }
    .pulse-kpi { background: white; border-radius: 12px; border: 1px solid #e8e4dc; padding: 18px 20px; position: relative; overflow: hidden; }
    .pulse-kpi::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; }
    .pulse-kpi.kpi-green::before { background: linear-gradient(90deg, #4ade80, #2d7a5e); }
    .pulse-kpi.kpi-blue::before { background: linear-gradient(90deg, #60a5fa, #2563eb); }
    .pulse-kpi.kpi-amber::before { background: linear-gradient(90deg, #fbbf24, #d97706); }
    .pulse-kpi.kpi-orange::before { background: linear-gradient(90deg, #fb923c, #c2410c); }
    .pulse-kpi .kpi-val { font-size: 36px; font-weight: 900; color: #1a2e2a; line-height: 1; margin-top: 4px; }
    .pulse-kpi .kpi-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #7a7a6e; }
    .pulse-kpi .kpi-sub { font-size: 11px; color: #aaa; margin-top: 4px; }
    .pulse-kpi .kpi-trend { position: absolute; top: 18px; right: 18px; font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 20px; }
    .trend-up { background: #dcfce7; color: #166534; }
    .trend-new { background: #dbeafe; color: #1e40af; }

    .pulse-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    @media (max-width: 700px) { .pulse-grid { grid-template-columns: 1fr; } }

    .pulse-card { background: white; border-radius: 12px; border: 1px solid #e8e4dc; padding: 18px 20px; }
    .pulse-card-title { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #7a7a6e; margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
    .pulse-card-title span { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
    .span-green { background: #4ade80; }
    .span-blue { background: #60a5fa; }

    .pulse-query-row { display: flex; align-items: center; gap: 10px; padding: 7px 0; border-bottom: 1px solid #f4f1eb; }
    .pulse-query-row:last-child { border-bottom: none; }
    .pulse-query-rank { font-size: 11px; font-weight: 700; color: #aaa; min-width: 20px; }
    .pulse-query-text { flex: 1; min-width: 0; font-size: 12px; color: #2c2c2c; white-space: normal; overflow-wrap: anywhere; word-break: break-word; }
    .pulse-query-pos { font-size: 11px; font-weight: 700; color: #2d7a5e; background: #f0faf5; border-radius: 6px; padding: 2px 7px; }
    .pulse-query-imp { font-size: 11px; color: #aaa; min-width: 50px; text-align: right; }

    .pulse-page-row { display: flex; align-items: flex-start; gap: 10px; padding: 7px 0; border-bottom: 1px solid #f4f1eb; }
    .pulse-page-row:last-child { border-bottom: none; }
    .pulse-page-url { flex: 1; min-width: 0; font-size: 11px; color: #2d7a5e; overflow-wrap: anywhere; word-break: break-word; }
    .pulse-page-meta { display: flex; gap: 6px; flex-shrink: 0; }
    .pulse-badge { font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 20px; }
    .badge-clicks { background: #dcfce7; color: #166534; }
    .badge-impr { background: #dbeafe; color: #1e40af; }
    .badge-pos { background: #fef3c7; color: #92400e; }

    .pulse-chart { margin-top: 4px; }
    .chart-bars { display: flex; align-items: flex-end; gap: 4px; height: 60px; }
    .chart-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; }
    .chart-bar { width: 100%; border-radius: 3px 3px 0 0; min-height: 2px; transition: height 0.3s; }
    .chart-bar.bar-impr { background: #bfdbfe; }
    .chart-bar.bar-click { background: #4ade80; }
    .chart-label { font-size: 9px; color: #aaa; }

    .pulse-insight { background: #f0faf5; border: 1px solid #c6e8da; border-radius: 10px; padding: 12px 16px; margin-top: 16px; display: flex; gap: 12px; align-items: flex-start; }
    .pulse-insight-icon { font-size: 18px; flex-shrink: 0; }
    .pulse-insight-text { font-size: 12px; color: #1a4f3a; line-height: 1.5; }
    .pulse-insight-text strong { font-weight: 700; }

    .pulse-footer-note { font-size: 11px; color: #aaa; margin-top: 16px; text-align: center; }
    .pulse-footer-note a { color: #2d7a5e; text-decoration: none; }
    .pulse-table-scroll { width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .pulse-table-scroll table { min-width: 720px; }

    @media (max-width: 640px) {
      body { overflow-x: hidden; }
      .header { padding: 22px 16px; display: block; }
      .header-brand { align-items: flex-start; }
      .header h1 { font-size: 19px; line-height: 1.2; word-break: break-word; }
      .header-meta { text-align: left; margin-top: 18px; }
      .live-badge { display: flex; align-items: flex-start; width: 100%; border-radius: 14px; padding: 8px 10px; line-height: 1.45; white-space: normal; }
      .container { width: 100%; padding: 20px 12px; overflow: hidden; }
      .section-title { margin-top: 30px !important; font-size: 12px; line-height: 1.35; }
      .stats-grid, .info-grid, .pulse-grid, .pulse-kpi-row, .links-grid { grid-template-columns: 1fr !important; gap: 10px; }
      .pulse-card > div[style*="grid-template-columns:repeat(4,1fr)"],
      .pulse-card > div[style*="grid-template-columns:1fr 1fr"],
      div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns: 1fr !important; }
      .stat-card, .info-card, .pulse-card, .pulse-kpi, .link-card { padding: 14px; border-radius: 12px; max-width: 100%; }
      .stat-card .num, .pulse-kpi .kpi-val { font-size: 30px; }
      .pulse-kpi .kpi-trend { position: static; display: inline-block; margin-bottom: 8px; }
      .info-row { display: block; }
      .info-row .key, .info-row .val { display: block; text-align: left; }
      .info-row .val { margin-top: 4px; word-break: break-word; }
      .pulse-query-row, .pulse-page-row { align-items: flex-start; flex-wrap: wrap; gap: 6px; }
      .pulse-query-text, .pulse-page-url { min-width: 0; white-space: normal; overflow: visible; text-overflow: clip; word-break: break-word; }
      .pulse-page-meta { flex-wrap: wrap; width: 100%; }
      .pulse-query-imp { min-width: auto; text-align: left; }
      .pulse-insight { padding: 12px; gap: 10px; }
      .pulse-insight-text { font-size: 12px; word-break: break-word; }
      .pulse-table-scroll { margin: 0 -2px; }
      .content-card { overflow-x: auto; -webkit-overflow-scrolling: touch; }
      .content-table { min-width: 720px; }
      .changelog-item { display: block; padding: 14px; }
      .changelog-date { min-width: 0; margin-bottom: 6px; }
      .footer { padding: 24px 14px; line-height: 1.5; }
    }

    /* ── GROWTH DASHBOARD v19 ── */
    :root {
      --ink: #1a2e2a;
      --ink-soft: #2c4a44;
      --accent: #4e9e7e;
      --accent-dark: #2d7a5e;
      --paper-2: #faf8f4;
      --card: #ffffff;
      --border: #e8e4dc;
      --muted: #7a7a6e;
      --up: #16a34a;
      --down: #dc2626;
      --shadow: 0 4px 24px rgba(26, 46, 42, 0.06);
      --radius: 14px;
    }

    .kpi-strip {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-top: 8px;
      margin-bottom: 32px;
    }
    @media (max-width: 1100px) { .kpi-strip { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) { .kpi-strip { grid-template-columns: 1fr; } }
    .kpi-card {
      background: var(--card);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 18px 16px;
      box-shadow: var(--shadow);
    }
    .kpi-label {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
    }
    .kpi-value {
      font-size: 28px;
      font-weight: 800;
      color: var(--ink);
      margin: 6px 0 4px;
      letter-spacing: -0.02em;
      line-height: 1;
    }
    .kpi-delta {
      font-size: 11px;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      gap: 3px;
      padding: 2px 8px;
      border-radius: 999px;
    }
    .kpi-delta.up { background: #dcfce7; color: var(--up); }
    .kpi-delta.down { background: #fee2e2; color: var(--down); }
    .kpi-delta.neutral { background: #f3f4f6; color: var(--muted); }
    .kpi-sub { font-size: 10px; color: #aaa; margin-top: 6px; line-height: 1.35; }

    /* ── Sections ── */
    .section { margin-bottom: 48px; }
    .section-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 20px;
    }
    .section-head h2 {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 24px;
      font-weight: 700;
      color: var(--ink);
    }
    .section-head p { font-size: 13px; color: var(--muted); max-width: 480px; }
    .badge-src {
      font-size: 11px;
      font-weight: 600;
      color: var(--accent-dark);
      background: #f0faf5;
      border: 1px solid #c6e8da;
      border-radius: 999px;
      padding: 4px 12px;
    }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
    @media (max-width: 900px) { .grid-2, .grid-3 { grid-template-columns: 1fr; } }

    .card {
      background: var(--card);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 24px;
      box-shadow: var(--shadow);
    }
    .card-title {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      margin-bottom: 16px;
    }
    .chart-wrap { position: relative; height: 280px; }
    .chart-wrap-sm { height: 220px; }

    /* ── Monthly table ── */
    .data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .data-table th {
      text-align: left;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--muted);
      padding: 10px 14px;
      border-bottom: 2px solid var(--border);
      font-weight: 700;
    }
    .data-table td {
      padding: 12px 14px;
      border-bottom: 1px solid #f4f1eb;
      vertical-align: middle;
    }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: var(--paper-2); }
    .data-table .num { font-weight: 800; font-size: 15px; color: var(--accent-dark); }
    .bar-cell { display: flex; align-items: center; gap: 10px; }
    .mini-bar {
      height: 6px;
      border-radius: 3px;
      background: linear-gradient(90deg, var(--accent), var(--accent-dark));
      min-width: 4px;
    }

    /* ── Query / page rows ── */
    .rank-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 0;
      border-bottom: 1px solid #f4f1eb;
      font-size: 12px;
    }
    .rank-row:last-child { border-bottom: none; }
    .rank-num { font-weight: 800; color: #ccc; min-width: 22px; font-size: 11px; }
    .rank-text { flex: 1; min-width: 0; word-break: break-word; color: var(--ink); }
    .rank-url { flex: 1; min-width: 0; word-break: break-all; color: var(--accent-dark); font-size: 11px; }
    .pill {
      font-size: 10px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 999px;
      white-space: nowrap;
    }
    .pill-green { background: #dcfce7; color: #166534; }
    .pill-blue { background: #dbeafe; color: #1e40af; }
    .pill-amber { background: #fef3c7; color: #92400e; }

    /* ── Insight ── */
    .insight {
      background: linear-gradient(135deg, #f0faf5, #ecfdf5);
      border: 1px solid #c6e8da;
      border-radius: 12px;
      padding: 16px 20px;
      font-size: 13px;
      color: var(--ink-soft);
      line-height: 1.55;
      margin-top: 20px;
    }
    .insight strong { color: var(--ink); }

    /* ── Timeline ── */
    .timeline { position: relative; padding-left: 28px; }
    .timeline::before {
      content: '';
      position: absolute;
      left: 7px;
      top: 8px;
      bottom: 8px;
      width: 2px;
      background: linear-gradient(180deg, var(--accent), var(--border));
    }
    .tl-item { position: relative; padding-bottom: 24px; }
    .tl-item:last-child { padding-bottom: 0; }
    .tl-dot {
      position: absolute;
