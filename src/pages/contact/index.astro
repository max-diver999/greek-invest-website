---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
import { SITE } from '../../data/site';
---
<BaseLayout
  title="Contact Greek Invest"
  description={`Contact Greek Invest at ${SITE.email} or request a free Greece property shortlist.`}
>
  <section class="site-container py-12 md:py-16 max-w-2xl">
    <h1 class="mb-4">Contact</h1>
    <p class="text-[var(--color-muted)] mb-8">
      Editorial questions: <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
      For property shortlists, use the form below or{' '}
      <a
        href={`${SITE.whatsapp}?text=Hi%2C%20I%20need%20help%20with%20a%20property%20enquiry%20from%20Greek%20Invest.`}
        target="_blank"
        rel="noopener noreferrer"
        data-wa-placement="footer_contact"
        data-cta="whatsapp_contact_page"
      >
        WhatsApp {SITE.whatsappDisplay}
      </a>.
      We usually reply within one business day.
    </p>
    <LeadForm context="Contact page" />
  </section>
</BaseLayout>
