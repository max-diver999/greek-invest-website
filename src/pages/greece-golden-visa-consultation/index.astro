---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';

const title = 'Greece Golden Visa Consultation — Property Route 2026';
const description = 'Golden Visa consultation for Greece: €400K vs €800K tiers, 120m² rule, lawyer-ready checklist, and vetted property shortlist. Independent advisory.';
---

<BaseLayout
  {title}
  {description}
  canonical="https://greek-invest.com/greece-golden-visa-consultation/"
>
  <section class="bg-[#0f2744] text-white">
    <div class="site-container py-14 md:py-20 max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-[#93c5fd] mb-3">Golden Visa · Property route</p>
      <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-4 text-white">Greece Golden Visa consultation</h1>
      <p class="text-lg text-[#cbd5e1] leading-relaxed mb-6">
        Greece is the only major EU market still offering a direct property-backed Golden Visa in 2026.
        We help you match tier, location, and file-ready stock before you instruct lawyers or transfer funds.
      </p>
      <ul class="space-y-2 text-[#e2e8f0] list-disc pl-5 mb-8">
        <li>€800K Attica / Thessaloniki / Mykonos / Santorini vs €400K regional routing</li>
        <li>120 m² single-property rule and no-STR compliance on the qualifying asset</li>
        <li>8,879 approvals in 2025 — backlog-aware timeline planning</li>
      </ul>
      <a href="/get-shortlist/" class="btn-primary">Book Golden Visa shortlist</a>
    </div>
  </section>

  <section class="site-container py-12 max-w-3xl text-[var(--color-muted)] leading-relaxed">
    <h2 class="text-[var(--color-ink)] text-xl font-bold mb-4">What we cover</h2>
    <table class="w-full text-sm mb-10">
      <thead>
        <tr class="border-b border-[var(--color-border)] text-left">
          <th class="py-2 pr-4">Step</th>
          <th class="py-2">Deliverable</th>
        </tr>
      </thead>
      <tbody>
        <tr class="border-b border-[var(--color-border)]">
          <td class="py-3 pr-4 font-medium text-[var(--color-ink)]">1. Tier & zone</td>
          <td class="py-3">Confirm €400K vs €800K using address-level routing — <a href="/tools/greece-golden-visa-zone-lookup/">zone checker</a></td>
        </tr>
        <tr class="border-b border-[var(--color-border)]">
          <td class="py-3 pr-4 font-medium text-[var(--color-ink)]">2. Property fit</td>
          <td class="py-3">120 m² engineer check, single title, resale vs off-plan trade-offs</td>
        </tr>
        <tr class="border-b border-[var(--color-border)]">
          <td class="py-3 pr-4 font-medium text-[var(--color-ink)]">3. Cost stack</td>
          <td class="py-3">All-in model via <a href="/tools/greece-property-cost-calculator/">cost calculator</a> + lawyer fees</td>
        </tr>
        <tr>
          <td class="py-3 pr-4 font-medium text-[var(--color-ink)]">4. File path</td>
          <td class="py-3">AFM, bank account, migration lawyer handoff — <a href="/guides/greece-golden-visa-timeline-application-2026/">timeline guide</a></td>
        </tr>
      </tbody>
    </table>

    <p class="mb-10">
      Start here:
      <a href="/guides/greece-golden-visa-property-guide-2026/">Golden Visa property guide</a> ·
      <a href="/guides/golden-visa-eligible-projects-directory/">eligible property framework</a> ·
      <a href="/tier-golden-visa-400k/">€400K regional route</a> ·
      <a href="/guides/greece-golden-visa-property-tiers-2026/">tier map</a>
    </p>

    <LeadForm
      title="Request Golden Visa consultation"
      subtitle="Tier · 120m² · zone · vetted properties · no developer pressure"
      context="Golden Visa consultation page"
    />

    <p class="text-xs text-[var(--color-muted)] mt-8">
      Independent research — not immigration or tax advice. Greece granted 8,879 new Golden Visa approvals in 2025. Verify all rules with licensed Greek migration and property counsel.
    </p>
  </section>
</BaseLayout>
