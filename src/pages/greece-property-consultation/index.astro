---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';

const title = 'Greece Property Investment Consultation, Free Shortlist';
const description = 'Book a Greece property consultation: Golden Visa tiers, region fit, and vetted off-plan or resale options. Independent research, no developer pressure.';
---

<BaseLayout
  {title}
  {description}
  canonical="https://greek-invest.com/greece-property-consultation/"
>
  <section class="bg-[#0f2744] text-white">
    <div class="site-container py-14 md:py-20 max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-[#93c5fd] mb-3">Consultation</p>
      <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-4 text-white">Greece property investment consultation</h1>
      <p class="text-lg text-[#cbd5e1] leading-relaxed mb-8">
        One conversation to align budget, Golden Visa tier, and target region, then a curated shortlist screened for
        120 m², zone classification, and file-ready due diligence. Independent research, not a developer sales desk.
      </p>
      <ul class="space-y-2 text-[#e2e8f0] mb-0 list-disc pl-5">
        <li>€400K regional vs €800K Attica routing</li>
        <li>Resale (78% of foreign buyers) vs off-plan trade-offs</li>
        <li>Lawyer, engineer, and AFM sequence before you deposit</li>
      </ul>
    </div>
  </section>

  <section class="site-container py-12 max-w-2xl">
    <h2 class="text-xl font-bold mb-4">What we cover in the first call</h2>
    <table class="w-full text-sm mb-10">
      <thead>
        <tr class="border-b border-[var(--color-border)] text-left">
          <th class="py-2 pr-4">Topic</th>
          <th class="py-2">Outcome</th>
        </tr>
      </thead>
      <tbody class="text-[var(--color-muted)]">
        <tr class="border-b border-[var(--color-border)]">
          <td class="py-3 pr-4 font-medium text-[var(--color-ink)]">Golden Visa fit</td>
          <td class="py-3">Correct €400K / €800K / €250K route for your target address</td>
        </tr>
        <tr class="border-b border-[var(--color-border)]">
          <td class="py-3 pr-4 font-medium text-[var(--color-ink)]">Region shortlist</td>
          <td class="py-3">Athens, Crete, Cyclades, Peloponnese, or Thessaloniki matched to goal</td>
        </tr>
        <tr class="border-b border-[var(--color-border)]">
          <td class="py-3 pr-4 font-medium text-[var(--color-ink)]">Total cost model</td>
          <td class="py-3">Purchase price + 7 to 10% acquisition stack (FMA, notary, legal)</td>
        </tr>
        <tr>
          <td class="py-3 pr-4 font-medium text-[var(--color-ink)]">Next steps</td>
          <td class="py-3">Lawyer intro, zone checker, and 3 to 5 vetted properties if criteria clear</td>
        </tr>
      </tbody>
    </table>

    <p class="text-sm text-[var(--color-muted)] mb-8">
      Background reading:
      <a href="/guides/greece-golden-visa-property-guide-2026/">Golden Visa property guide</a> ·
      <a href="/tools/greece-golden-visa-zone-lookup/">Zone checker</a> ·
      <a href="/guides/golden-visa-eligible-projects-directory/">Eligible property framework</a> ·
      <a href="/guides/cost-of-buying-property-greece/">Buying costs</a>
    </p>

    <LeadForm
      title="Request your consultation"
      subtitle="Budget · region · Golden Visa · resale or off-plan"
      context="Greece property consultation page"
    />

    <p class="text-xs text-[var(--color-muted)] mt-8">
      Not immigration, tax, or investment advice. Verify all figures with licensed Greek counsel before transfer.
    </p>
  </section>
</BaseLayout>
