---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
import InlineCta from '../../components/InlineCta.astro';

const title = 'Invest in Crete Property 2026 — €400K Golden Visa';
const description = 'Invest in Crete property from €400,000 Golden Visa tier. Chania, Heraklion, Elounda markets — 120m² rule, yields, and vetted shortlist.';
---

<BaseLayout
  {title}
  {description}
  canonical="https://greek-invest.com/invest-crete-property/"
>
  <section class="bg-[#0f2744] text-white">
    <div class="site-container py-14 md:py-18 max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-[#93c5fd] mb-3">Crete · Regional Golden Visa</p>
      <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-4 text-white">Invest in Crete property at the €400,000 tier</h1>
      <p class="text-lg text-[#cbd5e1] leading-relaxed mb-6">
        Crete sits outside Greece's €800,000 prime zones. One qualifying property from €400,000 with at least 120 m²,
        island-wide asking prices near €2,105/m², and long-term rental yields of 5–6% in Chania and Heraklion.
      </p>
      <a href="/get-shortlist/" class="btn-primary">Get Crete shortlist</a>
    </div>
  </section>

  <section class="site-container py-12 max-w-3xl text-[var(--color-muted)] leading-relaxed">
    <h2 class="text-[var(--color-ink)] mb-4">Where buyers focus on Crete</h2>
    <table class="w-full text-sm mb-8">
      <thead>
        <tr class="border-b border-[var(--color-border)] text-left">
          <th class="py-2 pr-4">Market</th>
          <th class="py-2 pr-4">Indicative €/m²</th>
          <th class="py-2">Guide</th>
        </tr>
      </thead>
      <tbody>
        <tr class="border-b border-[var(--color-border)]">
          <td class="py-3 pr-4">Chania</td>
          <td class="py-3 pr-4">€2,200–2,400</td>
          <td class="py-3"><a href="/areas/chania-property-investment/">Chania guide</a></td>
        </tr>
        <tr class="border-b border-[var(--color-border)]">
          <td class="py-3 pr-4">Heraklion</td>
          <td class="py-3 pr-4">€1,800–2,200</td>
          <td class="py-3"><a href="/areas/heraklion-property-investment/">Heraklion guide</a></td>
        </tr>
        <tr>
          <td class="py-3 pr-4">Elounda</td>
          <td class="py-3 pr-4">€4,000–8,000</td>
          <td class="py-3"><a href="/areas/elounda-property-investment/">Elounda guide</a></td>
        </tr>
      </tbody>
    </table>

    <InlineCta
      text="Compare Crete with Cyclades island pricing before you choose an island strategy."
      buttonText="Crete vs Cyclades compare"
      buttonHref="/compare/crete-vs-cyclades-property-investment/"
    />

    <p class="mb-10">
      Deep dives: <a href="/guides/crete-property-investment-guide/">Crete investment hub</a> ·
      <a href="/guides/crete-golden-visa-400000-property/">€400K Golden Visa guide</a> ·
      <a href="/tier-golden-visa-400k/">€400K tier overview</a> ·
      <a href="/guides/greece-golden-visa-no-short-term-rental/">GV rental rules</a>
    </p>

    <LeadForm
      title="Request Crete property shortlist"
      subtitle="Chania · Heraklion · Elounda · GV 120m² screening"
      context="Invest Crete commercial page"
    />
  </section>
</BaseLayout>
