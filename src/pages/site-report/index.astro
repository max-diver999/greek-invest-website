      <div class="sublabel">~2,433 avg/article · qa:full 5/5 PASS</div>
    </div>
    <div class="stat-card">
      <div class="num gold">113</div>
      <div class="label">URLs in sitemap (live)</div>
      <div class="sublabel">HTTP fetch sitemap-index.xml · 19 June 2026</div>
    </div>
    <div class="stat-card">
      <div class="num green">113</div>
      <div class="label">URLs sent (Google API)</div>
      <div class="sublabel">greek-invest-indexing · explicit batches · gap 0</div>
    </div>
    <div class="stat-card">
