---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LeadForm from '../../../components/LeadForm.astro';
import GreeceRentalYieldCalc from '../../../components/GreeceRentalYieldCalc.astro';
import FaqBlock from '../../../components/FaqBlock.astro';

const title = 'Greece Rental Yield Calculator 2026, Gross vs Net';
const description = 'Calculate gross and net rental yield for Greek property. Model rent, ENFIA, management, vacancy and tax before you buy to let in Athens, Crete or Thessaloniki.';

const faq = [
  {
    question: 'What is a typical gross rental yield in Athens?',
    answer: 'Athens city-wide gross long-term rental yield averaged about 5.43% in Global Property Guide data for late 2025. Working-class northern districts such as Kipseli can reach 6 to 7.5% gross, while the Athenian Riviera often runs 4.5 to 5.5% gross on premium stock.',
  },
  {
    question: 'How is net yield different from gross yield in Greece?',
    answer: 'Gross yield divides annual rent by purchase price before expenses. Net yield subtracts ENFIA, management, vacancy, maintenance, and rental income tax. Net typically lands 40 to 55% below the gross headline on the same asset.',
  },
  {
    question: 'Can I use Airbnb income in this calculator for a Golden Visa property?',
    answer: 'No. Law 5100/2024 prohibits short-term tourist rentals on the qualifying Golden Visa asset. Model long-term residential rent only on the GV property. STR assumptions belong on separate non-GV units.',
  },
  {
    question: 'What income tax rate should I enter?',
    answer: 'Greek rental income tax is progressive, 15% on the first €12,000 of annual rental income and higher bands above that for individuals. The calculator uses a flat percentage you choose as a planning shortcut, not a full tax return.',
  },
  {
    question: 'Where can I compare yields by city?',
    answer: 'The highest rental yield areas in Greece guide lists indicative gross yields for Athens, Thessaloniki, Crete, Patras, and Kavala with disclaimers on net drag.',
  },
  {
    question: 'Does yield alone justify a Golden Visa purchase?',
    answer: 'Most Golden Visa buyers underwrite residency and capital preservation first, with LTR income as a secondary benefit. Use this tool alongside the buy-to-let guide and lawyer review, not as the sole investment test.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};

const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Greece Rental Yield Calculator',
  url: 'https://greek-invest.com/tools/greece-rental-yield-calculator/',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  description,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
};
---

<BaseLayout
  {title}
  {description}
  canonical="https://greek-invest.com/tools/greece-rental-yield-calculator/"
  schemas={[faqSchema, webAppSchema]}
>
  <article class="site-container py-12 md:py-16 max-w-3xl prose prose-stone">
    <header class="mb-8 not-prose">
      <p class="text-sm font-semibold text-[#1a6fb5] uppercase tracking-wide mb-2">Tool</p>
      <h1 class="mb-3">{title}</h1>
      <p class="text-lg text-[var(--color-muted)] leading-relaxed">
        Model gross and net long-term rental yield before you buy. Adjust rent, ENFIA, management, vacancy, and a flat tax estimate.
      </p>
    </header>

    <GreeceRentalYieldCalc />

    <p>
      <strong>Quick answer:</strong> Gross yield is annual rent divided by purchase price.
      Athens averaged <strong>5.43% gross</strong> in late 2025 surveys; net yield after ENFIA, management, vacancy, and income tax often falls to roughly
      <strong>2.5 to 3.5%</strong> on the same apartment unless you buy in a higher-yield district such as Kipseli.
    </p>

    <h2>How to Use This Calculator</h2>
    <ol>
      <li>Enter your all-in purchase budget (price plus acquisition costs if you want true net-on-capital).</li>
      <li>Add realistic long-term monthly rent from comparable listings, not STR peak season quotes.</li>
      <li>Include ENFIA and insurance in the annual fixed costs field.</li>
      <li>Set management and vacancy assumptions: 8% and 5% are common starting points for Athens LTR.</li>
      <li>Use the tax field as a flat planning rate; confirm progressive bands with a Greek accountant.</li>
    </ol>

    <h2>Indicative Gross Yields by Market</h2>
    <table>
      <thead>
        <tr><th>Market</th><th>Gross LTR range</th><th>Notes</th></tr>
      </thead>
      <tbody>
        <tr><td>Athens city average</td><td>~5.43%</td><td>Global Property Guide Nov 2025</td></tr>
        <tr><td>Athens north (Kipseli belt)</td><td>6 to 7.5%</td><td>Working-class LTR demand</td></tr>
        <tr><td>Athenian Riviera</td><td>4.5 to 5.5%</td><td>Lower yield, stronger capital focus</td></tr>
        <tr><td>Thessaloniki</td><td>5 to 6.5%</td><td>Student and young professional demand</td></tr>
        <tr><td>Crete cities</td><td>5 to 6%</td><td>GV properties: LTR only on qualifying asset</td></tr>
      </tbody>
    </table>

    <p>
      Full framework: <a href="/guides/greece-rental-yield-guide/">Greece rental yield guide</a>,
      <a href="/guides/gross-vs-net-yield-greece/">gross vs net yield explainer</a>,
      <a href="/guides/highest-rental-yield-areas-greece/">yield by area</a>,
      <a href="/guides/buy-to-let-greece-guide/">buy-to-let guide</a>.
      Golden Visa rental restrictions:
      <a href="/guides/greece-golden-visa-no-short-term-rental/">no STR on qualifying property</a>.
    </p>

    <h2>Limitations</h2>
    <p>
      This is a planning calculator, not a tax return. It does not model progressive Greek rental tax bands, furniture packs, major repairs, or mortgage interest.
      Short-term rental income is excluded by design for Golden Visa compliance planning.
      See <a href="/guides/greece-rental-income-tax-non-resident/">rental income tax for non-residents</a> for bracket detail.
    </p>

    <FaqBlock items={faq} />

    <LeadForm
      title="Need yield-screened properties?"
      subtitle="LTR-focused shortlists · GV-compliant · net yield sanity check"
      context="Rental yield calculator tool"
    />
  </article>
</BaseLayout>
