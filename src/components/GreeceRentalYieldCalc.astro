---
/** Indicative gross vs net rental yield — Greece planning only. */
---

<div class="gr-calc" id="gr-yield-calc">
  <div class="gr-calc__grid">
    <label class="gr-calc__field">
      <span>Purchase price (€)</span>
      <input type="number" id="yield-price" min="50000" step="1000" value="400000" />
    </label>
    <label class="gr-calc__field">
      <span>Monthly rent (€)</span>
      <input type="number" id="yield-rent" min="0" step="50" value="1800" />
    </label>
    <label class="gr-calc__field">
      <span>Annual ENFIA + fixed costs (€)</span>
      <input type="number" id="yield-enfia" min="0" step="50" value="1200" />
    </label>
    <label class="gr-calc__field">
      <span>Management fee (% of rent)</span>
      <input type="number" id="yield-mgmt" min="0" max="30" step="1" value="8" />
    </label>
    <label class="gr-calc__field">
      <span>Vacancy allowance (% of rent)</span>
      <input type="number" id="yield-vacancy" min="0" max="50" step="1" value="5" />
    </label>
    <label class="gr-calc__field">
      <span>Income tax estimate (% of rent)</span>
      <input type="number" id="yield-tax" min="0" max="45" step="1" value="15" />
    </label>
  </div>

  <div class="gr-calc__result" id="yield-result" aria-live="polite"></div>
</div>

<script>
  function pct(n) {
    return `${n.toFixed(2)}%`;
  }

  function recalc() {
    const price = Number(document.getElementById('yield-price')?.value) || 0;
    const rentMo = Number(document.getElementById('yield-rent')?.value) || 0;
    const enfia = Number(document.getElementById('yield-enfia')?.value) || 0;
    const mgmtPct = Number(document.getElementById('yield-mgmt')?.value) || 0;
    const vacPct = Number(document.getElementById('yield-vacancy')?.value) || 0;
    const taxPct = Number(document.getElementById('yield-tax')?.value) || 0;

    const rentYr = rentMo * 12;
    const gross = price > 0 ? (rentYr / price) * 100 : 0;
    const mgmt = rentYr * (mgmtPct / 100);
    const vacancy = rentYr * (vacPct / 100);
    const tax = rentYr * (taxPct / 100);
    const netIncome = rentYr - mgmt - vacancy - tax - enfia;
    const net = price > 0 ? (netIncome / price) * 100 : 0;

    const el = document.getElementById('yield-result');
    if (!el) return;

    el.innerHTML = `
      <p class="gr-calc__headline">Gross yield: <strong>${pct(gross)}</strong> · Net yield (est.): <strong>${pct(net)}</strong></p>
      <ul class="gr-calc__lines">
        <li>Annual rent: €${rentYr.toLocaleString('en-EU')}</li>
        <li>Management (${mgmtPct}%): −€${Math.round(mgmt).toLocaleString('en-EU')}</li>
        <li>Vacancy (${vacPct}%): −€${Math.round(vacancy).toLocaleString('en-EU')}</li>
        <li>Income tax est. (${taxPct}%): −€${Math.round(tax).toLocaleString('en-EU')}</li>
        <li>ENFIA + fixed: −€${Math.round(enfia).toLocaleString('en-EU')}</li>
        <li>Net cash before mortgage: €${Math.round(netIncome).toLocaleString('en-EU')}/yr</li>
      </ul>
      <p class="gr-calc__note">Gross figures match industry quoting (Athens ~5.43% city average). Net uses your inputs — progressive Greek rental tax may differ. Golden Visa qualifying assets cannot use STR income assumptions on the GV property.</p>
    `;
  }

  ['yield-price', 'yield-rent', 'yield-enfia', 'yield-mgmt', 'yield-vacancy', 'yield-tax'].forEach((id) => {
    document.getElementById(id)?.addEventListener('input', recalc);
  });
  recalc();
</script>

<style>
  .gr-calc {
    background: #f8fafc;
    border: 1px solid var(--color-border, #e7e5e4);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 2rem 0;
  }
  .gr-calc__grid {
    display: grid;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .gr-calc__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .gr-calc__field span {
    display: block;
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.35rem;
  }
  .gr-calc__field input[type='number'] {
    width: 100%;
    padding: 0.65rem 0.85rem;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    font-size: 1rem;
  }
  .gr-calc__result {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid #e2e8f0;
  }
  .gr-calc__headline {
    font-size: 1.15rem;
    margin: 0 0 0.75rem;
  }
  .gr-calc__lines {
    margin: 0 0 1rem;
    padding-left: 1.2rem;
    line-height: 1.7;
  }
  .gr-calc__note {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-muted, #57534e);
  }
</style>
